# ==============================================
# AI WhatsApp Channel Automation
# Environment Variables Template
# ==============================================

# Copy this file to .env and fill in your actual values
# NEVER commit .env to GitHub!

# ==============================================
# GEMINI AI
# ==============================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ==============================================
# WHAPI (WhatsApp API)
# ==============================================
# Get your token from: https://whapi.cloud
WHAPI_TOKEN=your_whapi_token_here
WHAPI_CHANNEL_ID=your_channel_id_here

# ==============================================
# CLOUDINARY (Image Storage)
# ==============================================
# Sign up at: https://cloudinary.com (free tier)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==============================================
# REDDIT API
# ==============================================
# Create app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=AI-WhatsApp-Bot/1.0

# ==============================================
# KAGGLE (Optional - for API triggering)
# ==============================================
# Get from: https://www.kaggle.com/settings
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
KAGGLE_NOTEBOOK_URL=your_notebook_url
